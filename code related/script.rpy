# Вы можете расположить сценарий своей игры в этом файле.

# Определение персонажей игры.
define main_char = Character('[name]', color="#dcdf7e")
define neighbor = Character('', color = "#f58757")
define concierge = Character('Татьяна Ивановна', color = "#663f80")
# Вместо использования оператора image можете просто
# складывать все ваши файлы изображений в папку images.
# Например, сцену bg room можно вызвать файлом "bg room.png",
# а eileen happy — "eileen happy.webp", и тогда они появятся в игре.

# Игра начинается здесь:
label start:

    $ my_rep = 0
    $ concierge = 0
    $ revolutionery = 0
    $ neighbor = 0
    "Внимаение, вы будете лицезреть историю от лица персонажа мужского пола"
    $ name = renpy.input("Как вас зовут?")
    $ name = name.strip() 
    scene gray
    'Перед вами открылся вид на унылую серую картиниу'
    'Куча однотипных пятиэтажных зданий создавали некую гнетущую атмосфру'
    'только где-то вдали виднелось главное здание страны'
    'место где сидели все высшие чины и выдавали новые указания'
    'правила в наше мире довольно жестоки и что было вчера,'
    'сегодня уже может стать запретом'
    'каждое утро начинается с одного и того же '
    'привычная машина отдела задержания гражданов, стояла около вашего общежития'
    'и в очередной раз выводила одного из ваших соседий'
    'все знали что больше его не увидят'
    'наконец отойдя от окна вы посмотрелись в зеркало'
    'вы были довольно бледны и какбуд-то более цветным чем остальные'
    'но спрашивая других все говорили что вы вероятнеевсего переработали'
    'и это так усталость на вас сказываеться'
    'Сегодня был особый день, юбилей компании в которой вы работали'
    main_char "Наверное стоит сегодня надеть галстук, осталось выбрать какой..."
    
    menu:
        "Надеть красный галстук":
            "Вы надели красный галстук"
            jump red_tie
        "Надеть синий галстук":
            "Вы надели синий галстук"
            jump blue_tie 
    

label blue_tie:
    scene dorm_bg
    show gg_def
    main_char "А мне нравится этот глстук"
    $ my_rep -=1
    'Кофе. Без кофе вообще никак.'
    'Сыплю три ложки вместо двух, пусть будет горько. Может, проснусь.'
    'А, кого я обманываю. Кофе не будит, он просто даёт иллюзию, что ты живой следующие полчаса.'

    'Выхожу на кухню. Холодильник гудит, как вчерашний вечер в голове.' 
    'Бутерброд. Наскоро. Жую и не чувствую вкуса. Просто калории.' 
    'Топливо для того, чтобы доехать до работы и обратно.'

    'Телефон. Тыц. Тыц. А, вот он. Пять пропущенных от тёти, три сообщения от коллеги с вопросом по поводу вчерашнего отчёта.'
    'Коллегу пошлю мысленно, тёте позвоню по пути. Или не позвоню. Завтра.'

    'Ключи… на месте. Кошелёк… есть.' 
    'Надеваю на себя невидимую капсулу «терпи и делай вид, что всё ок».'

    'Лифт не работает.'
    'Конечно, а чего я хотел? Пятый этаж пешком.'
    'Топ-топ-топ. Ступеньки, как дни недели.' 
    'Понедельник, вторник, среда… вот и пятый'
    scene dorm_entrance_bg
    show Tanya_def
    show Gg_def
    'О наша консъержка, Татьяна Ивановна, как всегда выглядит подозрительно счастливой.'
    'Не уж то снова в гороскопе сказали что у неё по знаку задиаку будет все хорошо.'
    "Здравствуйте Татьяна Иванова, как ваше утро?"

    "Доброе утро дружок, да потихоньку."
    "А ты снова на работу. Н моей памяти ты уже 7/0 работаешь"

    "Вам так просто кажется"
    'пробубнили вы и по привычки  после минутного молчания с кивком выйдя на улицу думаете как же сегодня пойдёте на работу.'
    show screen map
    return

